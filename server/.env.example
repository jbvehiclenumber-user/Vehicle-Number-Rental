## Server environment variables
## Copy to `server/.env` and fill real values.

# Node environment
NODE_ENV=development

# Frontend URL (used in reset link + CORS). Comma-separated allowed.
FRONTEND_URL=http://localhost:3000

# Resend API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address:
# - For local/dev without domain verification: use Resend default
# - For production: use an address from a verified domain in Resend
EMAIL_FROM=onboarding@resend.dev

# App name used in email subject/body
APP_NAME=넘버링크

